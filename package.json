{
  "name": "consultoria",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/run-next.js dev",
    "dev:turbopack": "node ./scripts/run-next.js dev --turbopack",
    "build": "node ./scripts/run-next.js build",
    "build:turbopack": "node ./scripts/run-next.js build --turbopack",
    "start": "node ./scripts/run-next.js start",
    "lint": "node ./scripts/run-next.js lint",
    "ux:prepare": "node ./scripts/ux-refactor-prep.mjs",
    "ux:design-system": "node ./scripts/ux-refactor-prep.mjs --design-only",
    "ux:inventory": "node ./scripts/ux-refactor-prep.mjs --inventory-only",
    "ux:brief": "node ./scripts/ux-refactor-prep.mjs --brief-only",
    "ux:search": "node ./scripts/ux-skill-search.mjs",
    "vercel:link": "pnpm dlx vercel link --yes",
    "deploy:preview": "pnpm dlx vercel --prebuilt",
    "deploy:prod": "pnpm dlx vercel deploy --prod --prebuilt || pnpm dlx vercel --prod"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.22",
    "lenis": "^1.3.11",
    "next": "15.5.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/eslint-plugin-next": "^15.5.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
